# Optional bootstrap admin. Used by lib/db.ts on startup.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Recommended in production. Required by /setup when configured.
AUTH_SETUP_TOKEN=

# Optional password pepper. Keep stable once users exist.
AUTH_PASSWORD_PEPPER=

# Set to true/1/yes to require login for read endpoints.
REQUIRE_AUTH_FOR_READS=false

# Public branding.
NEXT_PUBLIC_PRODUCT_NAME=CanteraHub
NEXT_PUBLIC_COMPANY_NAME=Tu empresa
NEXT_PUBLIC_COMPANY_LOGO=/brand/company-logo.png
