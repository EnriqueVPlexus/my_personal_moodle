# Optional bootstrap admin. Use only real secrets in .env.local, never commit them.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-long-password

# Required for /setup in production. In development, /setup works without it.
AUTH_SETUP_TOKEN=change-this-setup-token

# Optional server-side pepper added before password hashing.
AUTH_PASSWORD_PEPPER=change-this-random-pepper
